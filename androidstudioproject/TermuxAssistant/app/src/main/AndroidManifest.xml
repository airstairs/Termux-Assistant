<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.xthan.termux_assistant">

    <queries>
        <package android:name="com.termux" />
        <package android:name="com.termux.window" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Termux Assistant"
        android:theme="@android:style/Theme.NoDisplay">

        <service
            android:name=".AssistantService"
            android:label="Termux Assistant"
            android:permission="android.permission.BIND_VOICE_INTERACTION"
            android:exported="true">
            <meta-data
                android:name="android.voice_interaction"
                android:resource="@xml/assistant_service_config" />
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionService" />
            </intent-filter>
        </service>

        <service
            android:name=".AssistantSessionService"
            android:permission="android.permission.BIND_VOICE_INTERACTION"
            android:exported="true" />

    </application>
</manifest>